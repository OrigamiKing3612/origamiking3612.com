---
interface Props {
    title?: string;
    description?: string;
}

import Head from "../components/Head.astro";

import "../styles/global.css";

const { title = "OrigamiKing3612", description = "" } = Astro.props;
---

<html lang="en" class="light">
    <head>
        <Head title={title} description={description} />

        <slot name="head" />
    </head>
    <body>
        <main class="all">
            <slot />
        </main>
    </body>
</html>
